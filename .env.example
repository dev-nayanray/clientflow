# ── ClientFlow AI — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Your Project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON=your_supabase_anon_key_here

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PK=pk_live_your_stripe_publishable_key

# Create 3 products in Stripe Dashboard → Products → Add Product
# Then copy the Price IDs (starts with price_)
VITE_STRIPE_MONTHLY=price_monthly_1_dollar
VITE_STRIPE_YEARLY=price_yearly_10_dollar
VITE_STRIPE_LIFETIME=price_lifetime_50_dollar

# ── Optional: Anthropic (can also be entered in-app) ─────────────────────────
# VITE_ANTHROPIC_KEY=sk-ant-your_key_here
